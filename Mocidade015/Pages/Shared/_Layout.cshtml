@*
    Layout principal — Mocidade 015
    - Topbar responsiva com avatar/dropdown
    - Toast region
    - Footer institucional
*@
@using System.Security.Claims
@{
    var userName = User?.Identity?.Name ?? "";
    var isAuth = User?.Identity?.IsAuthenticated == true;
    var isAdmin = User?.IsInRole("Admin") ?? false;
    var initials = "";
    if (!string.IsNullOrEmpty(userName))
    {
        var parts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
    }
    var toastPayload = TempData["Toast"] as string;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#002244" />
    <title>@ViewData["Title"] · Mocidade 015</title>
    <link rel="icon" type="image/svg+xml" href="~/images/logo.svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body data-toast="@(string.IsNullOrEmpty(toastPayload) ? null : toastPayload)">
    <header>
        <nav class="navbar navbar-expand-lg navbar-glass">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                    <img src="~/images/logo.svg" alt="" width="28" height="28" />
                    <span>Mocidade 015</span>
                </a>

                <button class="btn btn-sm btn-outline-light d-lg-none" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#mobileMenu" aria-controls="mobileMenu"
                        aria-label="Abrir menu">
                    <i class="bi bi-list"></i>
                </button>

                <div class="d-none d-lg-flex align-items-center gap-2 ms-auto">
                    @if (isAuth)
                    {
                        <a asp-page="/App/Dashboard" class="nav-link">
                            <i class="bi bi-bus-front me-1"></i> Viagem
                        </a>
                        <a asp-page="/App/Acompanhantes" class="nav-link">
                            <i class="bi bi-people me-1"></i> Acompanhantes
                        </a>
                        <a asp-page="/App/Perfil" class="nav-link">
                            <i class="bi bi-person me-1"></i> Perfil
                        </a>

                        @if (isAdmin)
                        {
                            <a asp-page="/Admin/Index" class="nav-link text-warning fw-bold">
                                <i class="bi bi-shield-lock me-1"></i> Painel Admin
                            </a>
                        }

                        <div class="dropdown">
                            <button class="btn d-flex align-items-center gap-2 text-white p-1" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="avatar">@initials</span>
                                <span class="d-none d-xl-inline">@userName</span>
                                <i class="bi bi-caret-down-fill small"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><h6 class="dropdown-header">Olá, @userName</h6></li>
                                <li><a class="dropdown-item" asp-page="/App/Perfil"><i class="bi bi-person me-2"></i>Meu Perfil</a></li>
                                <li><a class="dropdown-item" asp-page="/App/Dashboard"><i class="bi bi-bus-front me-2"></i>Painel da Viagem</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-danger" asp-page="/Logout"><i class="bi bi-box-arrow-right me-2"></i>Sair</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-page="/Login" class="btn btn-outline-light btn-sm">Entrar</a>
                        <a asp-page="/Cadastro" class="btn btn-accent btn-sm">Criar conta</a>
                    }
                </div>
            </div>
        </nav>

        @* Off-canvas mobile *@
        <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="mobileMenuLabel">Menu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fechar"></button>
            </div>
            <div class="offcanvas-body">
                @if (isAuth)
                {
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="avatar">@initials</span>
                        <div>
                            <div class="fw-bold">@userName</div>
                            <small class="text-muted">@(isAdmin ? "Administrador" : "Passageiro")</small>
                        </div>
                    </div>
                    <div class="list-group list-group-flush">
                        <a asp-page="/App/Dashboard" class="list-group-item list-group-item-action"><i class="bi bi-bus-front me-2"></i>Viagem</a>
                        <a asp-page="/App/Acompanhantes" class="list-group-item list-group-item-action"><i class="bi bi-people me-2"></i>Acompanhantes</a>
                        <a asp-page="/App/Perfil" class="list-group-item list-group-item-action"><i class="bi bi-person me-2"></i>Perfil</a>
                        @if (isAdmin)
                        {
                            <a asp-page="/Admin/Index" class="list-group-item list-group-item-action text-warning"><i class="bi bi-shield-lock me-2"></i>Painel Admin</a>
                        }
                    </div>
                    <hr />
                    <a asp-page="/Logout" class="btn btn-outline-danger w-100"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
                }
                else
                {
                    <a asp-page="/Login" class="btn btn-brand w-100 mb-2">Entrar</a>
                    <a asp-page="/Cadastro" class="btn btn-ghost w-100">Criar conta</a>
                }
            </div>
        </div>
    </header>

    <main class="container py-4 py-lg-5">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 text-center text-sm-start">
            <small>© @DateTime.UtcNow.Year · Mocidade 015 · Sistema de Reservas</small>
            <small class="text-soft">Feito com <span aria-hidden="true">💙</span> para a Mocidade</small>
        </div>
    </footer>

    <div id="toast-region" class="toast-region" aria-live="polite" aria-atomic="true"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>