@page
@model Mocidade015.Pages.CadastroModel
@{
    ViewData["Title"] = "Criar conta";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card-elevated shadow-md p-4 p-lg-5">
            <div class="text-center mb-4">
                <div class="avatar avatar--lg mb-3 mx-auto" aria-hidden="true">
                    <i class="bi bi-person-plus"></i>
                </div>
                <h1 class="h4 fw-bold text-brand mb-1">Crie sua conta</h1>
                <p class="text-muted small mb-0">Leva menos de 1 minuto. Você precisa de um e-mail válido.</p>
            </div>

            <form method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Input.Nome" class="form-label"></label>
                        <input asp-for="Input.Nome" class="form-control" autocomplete="name" placeholder="Seu nome completo" />
                        <span asp-validation-for="Input.Nome" class="field-error"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="seu@email.com" />
                        <span asp-validation-for="Input.Email" class="field-error"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Input.Telefone" class="form-label"></label>
                        <input asp-for="Input.Telefone" class="form-control" data-mask="phone" placeholder="(11) 99999-9999" />
                        <span asp-validation-for="Input.Telefone" class="field-error"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Input.Rg" class="form-label"></label>
                        <input asp-for="Input.Rg" class="form-control" placeholder="00.000.000-0" />
                        <span asp-validation-for="Input.Rg" class="field-error"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Input.Senha" class="form-label"></label>
                        <input asp-for="Input.Senha" class="form-control" data-strength="true" autocomplete="new-password" placeholder="Mínimo 8 caracteres" />
                        <span asp-validation-for="Input.Senha" class="field-error"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Input.ConfirmarSenha" class="form-label"></label>
                        <input asp-for="Input.ConfirmarSenha" class="form-control" autocomplete="new-password" placeholder="Repita a senha" />
                        <span asp-validation-for="Input.ConfirmarSenha" class="field-error"></span>
                    </div>
                </div>

                <div class="form-check mt-3">
                    <input class="form-check-input" type="checkbox" id="termos" required>
                    <label class="form-check-label small" for="termos">
                        Li e aceito os termos de uso e a política de privacidade.
                    </label>
                </div>

                <button type="submit" class="btn btn-brand btn-lg w-100 mt-3">
                    <i class="bi bi-rocket-takeoff me-1"></i> Criar minha conta
                </button>
            </form>

            <div class="text-center mt-4">
                <small class="text-muted">Já tem conta?</small>
                <a asp-page="/Login" class="text-decoration-none fw-semibold ms-1">Entrar</a>
            </div>
        </div>
    </div>
</div>
