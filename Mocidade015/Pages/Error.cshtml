@page
@model Mocidade015.Pages.ErrorModel
@{
    ViewData["Title"] = "Erro inesperado";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="card-elevated mx-auto text-center p-5" style="max-width: 540px;">
        <div class="display-1 mb-3" aria-hidden="true">⚠️</div>
        <h1 class="h3 fw-bold text-brand mb-2">Algo deu errado</h1>
        <p class="text-muted mb-4">
            Encontramos um problema técnico ao processar sua solicitação.
            Nossa equipe já foi notificada. Tente novamente em instantes.
        </p>
        <a asp-page="/Index" class="btn btn-brand px-4">
            <i class="bi bi-arrow-left me-1"></i> Voltar ao início
        </a>
    </div>
</div>
