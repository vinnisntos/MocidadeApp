@page
@model Mocidade015.Pages.Admin.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Gestão de Embarque";
}

<div class="container-fluid mt-4" style="max-width: 1400px;">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-azul-escuro m-0">Painel Administrativo</h2>
            <p class="text-muted small m-0">Gerencie passageiros e lista de espera</p>
        </div>
        <button onclick="window.print()" class="btn btn-dark d-print-none shadow-sm text-nowrap">
            <i class="bi bi-printer"></i> Imprimir Listas
        </button>
    </div>

    @if (TempData["Mensagem"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3">@TempData["Mensagem"]</div>
    }

    @* SEÇÃO 1: RESUMO DE DEMANDA (BARRINHAS) *@
    <div class="mt-4 mb-5 d-print-none">
        <h4 class="fw-bold text-azul-escuro mb-3">⏳ Resumo de Demanda (Lista de Espera)</h4>
        <div class="row g-3">
            @foreach (var resumo in Model.ResumoEspera)
            {
                var capRef = 44; // Referência de um ônibus padrão
                var porcentagem = (resumo.Total * 100) / capRef;
                var corBarra = resumo.Total >= capRef ? "bg-danger" : (resumo.Total >= 20 ? "bg-warning" : "bg-info");

                <div class="col-12 col-md-4 col-xl-3">
                    <div class="card border-0 shadow-sm p-3 rounded-4 h-100">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold text-azul-escuro text-truncate">📍 @resumo.Terminal</span>
                            <span class="badge bg-dark">@resumo.Total pessoas</span>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated @corBarra" 
                                 role="progressbar" 
                                 style="width: @(porcentagem > 100 ? 100 : porcentagem)%;">
                            </div>
                        </div>
                        <small class="text-muted mt-2 d-block">
                            @(capRef - resumo.Total > 0 ? $"Faltam {capRef - resumo.Total} para um novo ônibus" : "Demanda crítica! Analisar novo fretamento.")
                        </small>
                    </div>
                </div>
            }
        </div>
    </div>

    @* SEÇÃO 2: RELATÓRIO DOS ÔNIBUS *@
    <div class="row g-4 mb-5">
        @foreach (var onibus in Model.RelatorioOnibus)
        {
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-header bg-azul-escuro text-white d-flex justify-content-between align-items-center py-3">
                        <span class="fw-bold">🚌 Ônibus #@onibus.Numero - @onibus.Terminal</span>
                        <span class="badge @(onibus.TotalOcupados >= onibus.LotacaoMaxima ? "bg-danger" : "bg-success")">
                            @onibus.TotalOcupados / @onibus.LotacaoMaxima Ocupados
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 400px;">
                            <table class="table table-hover table-sm mb-0 align-middle">
                                <thead class="table-light sticky-top text-nowrap">
                                    <tr>
                                        <th class="ps-3">Poltrona</th>
                                        <th>Passageiro</th>
                                        <th>Documento</th>
                                        <th>Telefone</th>
                                        <th class="text-center">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in onibus.Reservas)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold">#@r.Assento.Numero.ToString("D2")</td>
                                            <td>
                                                <span class="d-block fw-semibold text-truncate" style="max-width: 200px;">
                                                    @(r.Acompanhante?.Nome ?? r.Usuario.Nome)
                                                </span>
                                                <small class="text-muted">@(r.AcompanhanteId == null ? "Titular" : "Acompanhante")</small>
                                            </td>
                                            <td class="small text-nowrap">@(r.Acompanhante?.RgCpf ?? r.Usuario.Rg)</td>
                                            <td class="small text-nowrap">@(r.Acompanhante?.Telefone ?? r.Usuario.Telefone ?? "-")</td>
                                            <td class="text-center">
                                                <form method="post" asp-page-handler="CancelarReserva" asp-route-reservaId="@r.Id" 
                                                      onsubmit="return confirm('Liberar assento?');" class="d-inline">
                                                    <button class="btn btn-outline-danger btn-sm border-0" title="Remover Passageiro">
                                                        <i class="bi bi-person-x"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* SEÇÃO 3: TABELA DETALHADA DA LISTA DE ESPERA *@
    <div class="mt-5 d-print-none">
        <h4 class="fw-bold text-azul-escuro mb-3">📋 Detalhes da Fila</h4>
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light text-nowrap">
                        <tr>
                            <th class="ps-4">Solicitante</th>
                            <th>Telefone</th>
                            <th>Terminal</th>
                            <th>Data/Hora</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.FilaEspera.Any())
                        {
                            <tr><td colspan="5" class="text-center py-4 text-muted">Fila vazia.</td></tr>
                        }
                        @foreach (var espera in Model.FilaEspera)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@espera.Usuario?.Nome</td>
                                <td class="text-nowrap">@(espera.Usuario?.Telefone ?? "-")</td>
                                <td><span class="badge bg-warning text-dark">@espera.TerminalDesejado</span></td>
                                <td class="small text-muted text-nowrap">@espera.DataSolicitacao.ToString("dd/MM HH:mm")</td>
                                <td class="text-center">
                                    <form method="post" asp-page-handler="RemoverDaEspera" asp-route-esperaId="@espera.Id"
                                          onsubmit="return confirm('Remover da lista?');">
                                        <button class="btn btn-outline-danger btn-sm border-0" title="Remover da Espera">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-azul-escuro { background-color: #002244; }
    .text-azul-escuro { color: #002244; }
    
    /* Melhorias na barra de rolagem da tabela responsiva */
    .table-responsive::-webkit-scrollbar { height: 8px; width: 8px; }
    .table-responsive::-webkit-scrollbar-thumb { background: #ccc; border-radius: 4px; }
    .table-responsive::-webkit-scrollbar-track { background: #f1f1f1; }
    
    @@media print { 
        .d-print-none { display: none !important; } 
        .card { break-inside: avoid; border: 1px solid #ddd !important; }
        .table-responsive { overflow: visible !important; }
    }
</style>