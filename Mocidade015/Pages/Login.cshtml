@page
@model Mocidade015.Pages.LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-5">
        <div class="card-elevated shadow-md p-4 p-lg-5">
            <div class="text-center mb-4">
                <div class="avatar avatar--lg mb-3 mx-auto" aria-hidden="true">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h1 class="h4 fw-bold text-brand mb-1">Acessar sua conta</h1>
                <p class="text-muted small mb-0">Bem-vindo de volta! Entre com seus dados para gerenciar sua reserva.</p>
            </div>

            <form method="post" novalidate>
                <div asp-validation-summary="All" class="alert alert-danger py-2 small d-none" id="loginSummary"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <div class="input-group-icon">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="seu@email.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Senha" class="form-label d-flex justify-content-between align-items-center">
                        <span>Senha</span>
                        <a href="#" class="small text-decoration-none text-muted" tabindex="-1">Esqueci minha senha</a>
                    </label>
                    <div class="input-group-icon">
                        <i class="bi bi-key"></i>
                        <input asp-for="Input.Senha" class="form-control" autocomplete="current-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Senha" class="field-error"></span>
                </div>

                <button type="submit" class="btn btn-brand btn-lg w-100">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Entrar
                </button>
            </form>

            <div class="text-center mt-4">
                <small class="text-muted">Ainda não tem conta?</small>
                <a asp-page="/Cadastro" class="text-decoration-none fw-semibold ms-1">Cadastre-se aqui</a>
            </div>
        </div>

        <p class="text-center text-muted small mt-3">
            <i class="bi bi-lock me-1"></i> Suas informações são protegidas e criptografadas.
        </p>
    </div>
</div>

@section Scripts {
    <script>
        // Mostra o validation-summary apenas se houver erro.
        (function () {
            var summary = document.getElementById('loginSummary');
            if (summary && summary.querySelector('.field-validation-error, .validation-summary-errors')) {
                summary.classList.remove('d-none');
            }
        })();
    </script>
}
